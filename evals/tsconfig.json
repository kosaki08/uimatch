{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "#plugin/*": ["../packages/uimatch-cli/src/*"],
      "@uimatch/cli": ["../packages/uimatch-cli/src/index.ts"],
      "@uimatch/core": ["../packages/uimatch-core/src/index.ts"],
      "@uimatch/scoring": ["../packages/uimatch-scoring/src/index.ts"],
      "@uimatch/selector-anchors": ["../packages/uimatch-selector-anchors/src/index.ts"],
      "@uimatch/selector-spi": ["../packages/uimatch-selector-spi/src/index.ts"],
      "@uimatch/shared-logging": ["../packages/shared-logging/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["**/*.ts", "../test-utils/fixture-server.ts"],
  "exclude": ["node_modules", "results"]
}
