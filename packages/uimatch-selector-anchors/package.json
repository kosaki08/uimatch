{
  "name": "@uimatch/selector-anchors",
  "version": "0.1.1",
  "description": "Selector resolution plugin for uiMatch using AST-based anchors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "uimatch-anchors": "./dist/cli/add-anchor.js"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --root ../.. packages/uimatch-selector-anchors"
  },
  "keywords": [
    "uimatch",
    "selector",
    "ast",
    "anchors"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kosaki08/uimatch.git",
    "directory": "packages/uimatch-selector-anchors"
  },
  "engines": {
    "node": ">=20.19 <21 || >=22.12"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "dependencies": {
    "parse5": "^8.0.1",
    "safe-regex2": "^5.1.1",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "re2": "^1.26.0"
  },
  "peerDependencies": {
    "@uimatch/selector-spi": "^0.1.1"
  },
  "peerDependenciesMeta": {
    "@uimatch/selector-spi": {
      "optional": false
    }
  },
  "devDependencies": {
    "@uimatch/selector-spi": "workspace:^",
    "rimraf": "^6.1.3"
  }
}
