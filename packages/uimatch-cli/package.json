{
  "name": "@uimatch/cli",
  "version": "0.4.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kosaki08/uimatch.git",
    "directory": "packages/uimatch-cli"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli/index.js"
  },
  "bin": {
    "uimatch": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "imports": {
    "#plugin/*": "./dist/*"
  },
  "scripts": {
    "build": "tsup --tsconfig tsconfig.build.json",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public",
    "linkWorkspacePackages": false
  },
  "engines": {
    "node": ">=20.19 <21 || >=22.12"
  },
  "dependencies": {
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@uimatch/selector-anchors": "^0.2.0",
    "playwright": ">=1.49.0"
  },
  "peerDependenciesMeta": {
    "@uimatch/selector-anchors": {
      "optional": true
    },
    "playwright": {
      "optional": false
    }
  },
  "devDependencies": {
    "@uimatch/core": "workspace:^",
    "@uimatch/scoring": "workspace:^",
    "@uimatch/selector-anchors": "workspace:^",
    "@uimatch/selector-spi": "workspace:^",
    "@uimatch/shared-logging": "workspace:^",
    "globby": "^14.1.0",
    "tsup": "^8.5.1"
  }
}
