{
  "name": "@uimatch/scoring",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Design Fidelity Score (DFS) calculation for uiMatch",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20.19 <21 || >=22.12"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc --project tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "vitest run --root ../.. packages/uimatch-scoring",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "design-fidelity",
    "scoring",
    "uimatch"
  ],
  "dependencies": {
    "@uimatch/core": "workspace:^"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
